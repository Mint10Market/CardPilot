{
  "name": "card-pilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "check": "npm run lint && npm run build",
    "check:full": "npm run check && npm run test",
    "verify:secrets": "bash scripts/verify-no-secrets.sh",
    "verify:secrets:scan": "bash scripts/scan-history-for-secrets.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "align:check": "node scripts/verify-alignment.mjs",
    "apply:0005": "node scripts/apply-migration-0005.mjs",
    "apply:0006": "node scripts/apply-migration-0006.mjs",
    "trigger:dev": "npx trigger.dev@latest dev",
    "trigger:deploy": "npx trigger.dev@latest deploy"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.1.3",
    "next": "16.1.6",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@trigger.dev/sdk": "^4.4.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
