# Copy to .env.local and fill in real values. Never commit .env.local or real secrets.
# If any of these were ever committed, rotate: Supabase DB password, eBay keys, webhook token, session secret.

# Database. Ports: 5432 = direct, 6543 = pooler (use pooler on Vercel).
# Local: use DATABASE_URL below. Vercel: use Shared Pooler URI (port 6543) as DATABASE_URL or SUPABASE_DB_URL.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# eBay OAuth (from eBay Developer Portal)
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret
# MUST match the host users actually open (e.g. card-pilot.vercel.app). Register this exact URL in eBay Developer Portal.
# If EBAY_REDIRECT_URI uses a different host (e.g. card-pilot-xyz.vercel.app), the state cookie won't be sent and you'll get "Session state didn't match".
EBAY_REDIRECT_URI=https://card-pilot.vercel.app/api/auth/ebay/callback
EBAY_ENVIRONMENT=production

# eBay Marketplace Account Deletion webhook (32–80 chars, alphanumeric, _, -)
EBAY_WEBHOOK_VERIFICATION_TOKEN=your_webhook_verification_token

# Same host as EBAY_REDIRECT_URI (e.g. https://card-pilot.vercel.app). Users must open this URL.
NEXT_PUBLIC_APP_URL=https://card-pilot.vercel.app

# Session (min 32 chars; use a long random string)
SESSION_SECRET=your_session_secret_at_least_32_characters

# Scheduled eBay sync (Vercel Cron). Set in Vercel env; cron requests must send Authorization: Bearer <CRON_SECRET>.
# Generate a long random string. Required for /api/sync/scheduled and /api/shows/refresh (cron) to run.
CRON_SECRET=your_cron_secret_for_scheduled_sync

# Optional JSON feed of card shows (used by json-feed show source adapter).
# If set, /api/shows/refresh will pull from this URL on each refresh and aggregate into card_shows.
# Expected shape: an array of objects with at least: id, name, startDate, city/state or venue.
CARD_SHOWS_FEED_URL=https://your-domain.com/card-shows.json
